# This file should contain secrets which are used inside the agent (apps/agents)

# LangSmith tracing
LANGSMITH_TRACING="true"
LANGSMITH_API_KEY=""
# Optional, unless using a non default project
# LANGCHAIN_PROJECT=""

# ---LLM API Keys---

# Anthropic
ANTHROPIC_API_KEY=""
# OpenAI
OPENAI_API_KEY=""
# Azure OpenAI
_AZURE_OPENAI_API_KEY=""
_AZURE_OPENAI_API_DEPLOYMENT_NAME=""
_AZURE_OPENAI_API_VERSION=""
_AZURE_OPENAI_API_BASE_PATH=""
# Fireworks
FIREWORKS_API_KEY=""
# Gemini
GOOGLE_API_KEY=""
# Groq - STT
GROQ_API_KEY=""
# ------------------

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE=""

FIRECRAWL_API_KEY=""

# ---GPT Researcher (Deep Research) ---
# Required for GPT Researcher MCP integration
# Ensure the `gpt_researcher` Python package is installed:
#   pip install gpt-researcher
# The MCP server wrapper will be fetched automatically on first use via:
#   npx -y gpt-researcher-mcp
TAVILY_API_KEY=""
# Optional: override default models used by GPT Researcher
# GPT_RESEARCHER_LLM_PROVIDER=""    # e.g. "openai" (default); note: lowercase key required by gpt-researcher-mcp
# GPT_RESEARCHER_FAST_LLM=""        # e.g. "openai:gpt-4o-mini"
# GPT_RESEARCHER_SMART_LLM=""       # e.g. "openai:gpt-4o"
# GPT_RESEARCHER_STRATEGIC_LLM=""   # e.g. "openai:gpt-4o"
# Override the command used to start the MCP server (default: npx)
# GPT_RESEARCHER_MCP_COMMAND=""
# Override the args passed to the MCP command (comma-separated, default: -y,gpt-researcher-mcp)
# GPT_RESEARCHER_MCP_ARGS=""
# ------------------------------------
